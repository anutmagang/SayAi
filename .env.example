# Copy to .env and adjust secrets before first boot.
# cp .env.example .env

POSTGRES_USER=sayai
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=sayai
POSTGRES_PORT=5432

REDIS_PORT=6379

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

API_PORT=8000

# Application
APP_NAME=SayAi
ENVIRONMENT=development
SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Used by /health/ready when set. For `docker compose` without the `full` profile (no Qdrant),
# leave empty so readiness stays green: QDRANT_URL=
QDRANT_URL=http://qdrant:6333

# LLM (LiteLLM)
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini
AGENT_MAX_STEPS=12
CHAT_MAX_TOOL_ROUNDS=2
SESSION_CONTEXT_MAX_MESSAGES=40
SESSION_REDIS_TTL_SECONDS=604800

# RAG / embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_DEFAULT_TOP_K=5

# Skill sandbox / packs (Phase 5)
SKILL_TOOL_TIMEOUT_SECONDS=30
# Optional: comma-separated hosts; when set, sayai.http_get may only call these hosts.
# SKILL_HTTP_HOST_ALLOWLIST=api.example.com,cdn.example.com
# Optional: extra directories (comma-separated) containing */manifest.json skill packs
# SKILL_PACKS_EXTRA_DIRS=/opt/sayai/packs

# Frontend (browser → API)
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
